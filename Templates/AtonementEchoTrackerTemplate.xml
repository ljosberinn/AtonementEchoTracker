<!-- this is CooldownViewerEssentialItemTemplate with minor modifications -->
<Ui
  xmlns="http://www.blizzard.com/wow/ui/"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.blizzard.com/wow/ui/ https://raw.githubusercontent.com/Gethe/wow-ui-source/live/Interface/AddOns/Blizzard_SharedXML/UI.xsd"
>
  <Frame
    name="AtonementEchoTrackerTemplate"
    virtual="true"
    ignoreParentAlpha="true"
    enableMouse="false"
    propagateMouseInput="Both"
  >
    <Layers>
      <Layer level="ARTWORK">
        <Texture parentKey="Icon" setAllPoints="true" />
        <MaskTexture atlas="UI-HUD-CoolDownManager-Mask" setAllPoints="true">
          <MaskedTextures>
            <MaskedTexture childKey="Icon" />
          </MaskedTextures>
        </MaskTexture>
      </Layer>
      <Layer level="OVERLAY">
        <Texture atlas="UI-HUD-CoolDownManager-IconOverlay" parentKey="Overlay">
          <Anchors>
            <Anchor point="TOPLEFT" x="-15" y="15" />
            <Anchor point="BOTTOMRIGHT" x="15" y="-15" />
          </Anchors>
        </Texture>
      </Layer>
    </Layers>
    <Frames>
      <Cooldown
        parentKey="Cooldown"
        setAllPoints="true"
        minimumCountdownDuration="0"
      >
        <SwipeTexture file="Interface\HUD\UI-HUD-CoolDownManager-Icon-Swipe">
          <Color r="0" g="0" b="0" a="0.7" />
        </SwipeTexture>
        <Layers>
          <Layer level="OVERLAY">
            <FontString
              parentKey="StackCount"
              font="GameFontHighlightHugeOutline"
              justifyH="RIGHT"
            >
              <Anchors>
                <Anchor point="BOTTOMRIGHT" />
              </Anchors>
            </FontString>
          </Layer>
        </Layers>
      </Cooldown>
    </Frames>
    <!-- <Scripts>
      <OnLoad method="OnLoad" />
      <OnSizeChanged method="OnSizeChanged" />
      <OnUpdate method="OnUpdate" />
    </Scripts> -->
  </Frame>
</Ui>